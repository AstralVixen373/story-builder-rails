<div class="page-header">
  <h1>Locations</h1>
  <%= link_to "New Location", new_location_path, class: "btn btn--primary" %>
</div>

<% if @locations.any? %>
  <div class="card-grid">
    <% @locations.each do |location| %>
      <div class="card">
        <h3><%= link_to location.name, location %></h3>
        <p class="card-meta"><%= pluralize(location.characters.size, "character") %></p>
        <p class="card-description"><%= truncate(location.description, length: 100) %></p>
        <div class="card-actions">
          <%= link_to "Edit", edit_location_path(location), class: "btn btn--sm" %>
          <%= button_to "Delete", location, method: :delete, class: "btn btn--sm btn--danger",
              data: { turbo_confirm: "Delete #{location.name}?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="empty-state">No locations yet. <%= link_to "Create your first location", new_location_path %>.</p>
<% end %>
