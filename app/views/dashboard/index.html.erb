<div class="dashboard">
  <h1>Story Builder</h1>

  <div class="nav-cards">
    <%= link_to characters_path, class: "nav-card" do %>
      <h3>Characters</h3>
      <p>Manage your cast</p>
    <% end %>
    <%= link_to locations_path, class: "nav-card" do %>
      <h3>Locations</h3>
      <p>Build your world</p>
    <% end %>
    <%= link_to chapters_path, class: "nav-card" do %>
      <h3>Chapters</h3>
      <p>Write your story</p>
    <% end %>
    <%= link_to relationships_path, class: "nav-card" do %>
      <h3>Relationships</h3>
      <p>Visualise connections</p>
    <% end %>
  </div>
  
  <div class="stat-cards">
    <div class="stat-card">
      <span class="stat-number"><%= @character_count %></span>
      <span class="stat-label">Characters</span>
    </div>
    <div class="stat-card">
      <span class="stat-number"><%= @location_count %></span>
      <span class="stat-label">Locations</span>
    </div>
    <div class="stat-card">
      <span class="stat-number"><%= @scene_count %></span>
      <span class="stat-label">Scenes</span>
    </div>
  </div>

  <div class="progress-section">
    <h2>Writing Progress</h2>
    <p><%= @word_count %> / 50,000 words</p>
    <div class="progress-bar">
      <div class="progress-fill" style="width: <%= [(@word_count / 50000.0 * 100).round, 100].min %>%"></div>
    </div>
  </div>

  <div class="recent-scenes">
    <h2>Recent Scenes</h2>
    <% if @recent_scenes.any? %>
      <ul>
        <% @recent_scenes.each do |scene| %>
          <li>
            <%= link_to scene.title.presence || "Untitled Scene", edit_chapter_scene_path(scene.chapter, scene) %>
            <span class="scene-chapter">— <%= scene.chapter.title %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No scenes yet. <%= link_to "Start writing", new_chapter_path %>.</p>
    <% end %>
  </div>
</div>
