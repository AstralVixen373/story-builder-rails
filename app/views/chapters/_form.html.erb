<%= form_with model: chapter, class: "form" do |f| %>
  <% if chapter.errors.any? %>
    <div class="form-errors">
      <% chapter.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :position, "Order" %>
    <%= f.number_field :position, class: "form-control", min: 1 %>
  </div>

  <div class="form-group">
    <%= f.label :description, "Summary (optional)" %>
    <%= f.text_area :description, rows: 4, class: "form-control" %>
  </div>

  <%= f.submit class: "btn btn--primary" %>
<% end %>
